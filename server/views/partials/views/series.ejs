<section class="view" id="series" aria-label="Series management">
  <div class="section-head">
    <h2>Series Library</h2>
    <span class="section-note">Create the show first, then manage its episodes from the series detail page.</span>
  </div>

  <div class="series-actions">
    <a class="primary-button" href="<%= basePath %>/admin/series/new">Create Series</a>
  </div>

  <div class="poster-grid">
    <% if (series.length === 0) { %>
      <article class="empty-card">No series yet.</article>
    <% } %>
    <% series.forEach((item) => { %>
      <article class="series-card">
        <% if (item.poster_url) { %>
          <div class="poster" style="background-image: url('<%= item.poster_url %>')"></div>
        <% } else { %>
          <div class="poster"></div>
        <% } %>
        <strong><%= item.title %></strong>
        <span><%= item.episode_count %> episodes · <span data-status-label><%= item.status %></span></span>
        <div class="series-card-actions">
          <a class="ghost-button" href="<%= basePath %>/admin/series/<%= item.series_id %>">Manage Episodes</a>
          <form class="inline-form" method="post" action="<%= basePath %>/admin/series/<%= item.id %>/status" data-status-form data-entity-type="series">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <input type="hidden" name="status" value="<%= item.status === 'live' ? 'draft' : 'live' %>" />
            <button class="ghost-button" type="submit" data-status-button><%= item.status === 'live' ? 'Move to Draft' : 'Publish' %></button>
          </form>
        </div>
      </article>
    <% }) %>
  </div>
</section>
