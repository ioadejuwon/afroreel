<section class="view" id="settings" aria-label="Settings">
  <div class="settings-grid">
    <article class="panel">
      <div class="panel-header"><h2>Access Rules</h2><span>MVP defaults</span></div>
      <label class="setting-row"><span>Free episodes per series</span><input type="number" value="5" /></label>
      <label class="setting-row"><span>Default unlock price</span><input type="number" value="5" /></label>
      <label class="setting-row"><span>Rewarded ad payout</span><input type="number" value="2" /></label>
    </article>
    <article class="panel">
      <div class="panel-header"><h2>Publishing</h2><span>Controls</span></div>
      <label class="toggle"><input type="checkbox" checked /> Require review before publishing</label>
      <label class="toggle"><input type="checkbox" checked /> Notify users for new episodes</label>
      <label class="toggle"><input type="checkbox" /> Enable creator submissions</label>
    </article>
  </div>
</section>
