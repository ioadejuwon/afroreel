<section class="view active" id="dashboard" aria-label="Dashboard">
  <div class="dashboard-hero">
    <div>
      <h2>Hello, <span><%= String(admin.name || "Admin").split(" ")[0] %></span></h2>
      <p>Plan releases, monitor growth, and keep the AfroReel catalog moving.</p>
    </div>
  </div>

  <div class="metric-grid">
    <article class="metric-card is-featured">
      <span>Total Viewers</span>
      <strong>24,890</strong>
      <em>+12.8% from last week</em>
    </article>
    <article class="metric-card">
      <span>Completions</span>
      <strong>68.4%</strong>
      <em>Broken Promises leads</em>
    </article>
    <article class="metric-card">
      <span>Unlock Rate</span>
      <strong>18.7%</strong>
      <em>+3.1% after episode 5</em>
    </article>
    <article class="metric-card">
      <span>Revenue/User</span>
      <strong>$0.42</strong>
      <em>Coins and rewarded ads</em>
    </article>
  </div>

  <div class="content-grid">
    <article class="panel span-2">
      <div class="panel-header">
        <h2>Weekly Watch Time</h2>
        <span>Minutes watched</span>
      </div>
      <div class="bar-chart" aria-label="Weekly watch time chart">
        <span style="height: 42%"></span>
        <span style="height: 55%"></span>
        <span style="height: 48%"></span>
        <span style="height: 72%"></span>
        <span style="height: 64%"></span>
        <span style="height: 88%"></span>
        <span style="height: 78%"></span>
      </div>
      <div class="chart-axis">
        <span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span><span>Sun</span>
      </div>
    </article>

    <article class="panel">
      <div class="panel-header">
        <h2>Release Focus</h2>
        <span>This week</span>
      </div>
      <div class="focus-card">
        <strong>Lagos Secrets</strong>
        <span>Episode 12 review</span>
        <button class="primary-button" type="button" data-view-target="episodes">Open Queue</button>
      </div>
    </article>

    <article class="panel span-2">
      <div class="panel-header">
        <h2>Priority Queue</h2>
        <span>Needs action</span>
      </div>
      <table>
        <thead>
          <tr><th>Title</th><th>Status</th><th>Owner</th><th>Due</th></tr>
        </thead>
        <tbody>
          <tr><td>Lagos Secrets Ep 12</td><td><span class="status review">Review</span></td><td>Ada</td><td>Today</td></tr>
          <tr><td>Broken Promises Poster</td><td><span class="status blocked">Blocked</span></td><td>Tunde</td><td>Tomorrow</td></tr>
          <tr><td>Campus Lies Trailer</td><td><span class="status live">Ready</span></td><td>Miriam</td><td>Fri</td></tr>
        </tbody>
      </table>
    </article>

    <article class="panel">
      <div class="panel-header">
        <h2>Coin Economy</h2>
        <span>Last 24h</span>
      </div>
      <div class="stack">
        <div><span>Purchased</span><strong>182k</strong></div>
        <div><span>Ad rewards</span><strong>76k</strong></div>
        <div><span>Spent</span><strong>149k</strong></div>
      </div>
    </article>
  </div>
</section>
