<section class="view active" id="dashboard" aria-label="Dashboard">
  <div class="dashboard-hero">
    <div>
      <h2>Hello, <span><%= String(admin.name || "Admin").split(" ")[0] %></span></h2>
      <p>Plan releases, monitor growth, and keep the AfroReel catalog moving.</p>
    </div>
  </div>

  <div class="metric-grid">
    <% dashboard.metrics.forEach((metric) => { %>
      <article class="metric-card<%= metric.featured ? ' is-featured' : '' %>">
        <span><%= metric.label %></span>
        <strong><%= metric.value %></strong>
        <em><%= metric.note %></em>
      </article>
    <% }) %>
  </div>

  <div class="content-grid">
    <article class="panel">
      <div class="panel-header">
        <h2>Release Focus</h2>
        <span>This week</span>
      </div>
      <div class="focus-card">
        <strong><%= dashboard.releaseFocus.title %></strong>
        <span><%= dashboard.releaseFocus.note %></span>
        <button class="primary-button" type="button" data-view-target="series"><%= dashboard.releaseFocus.actionLabel %></button>
      </div>
    </article>

    <article class="panel span-2">
      <div class="panel-header">
        <h2>Priority Queue</h2>
        <span>Needs action</span>
      </div>
      <table>
        <thead>
          <tr><th>Title</th><th>Status</th><th>Due</th></tr>
        </thead>
        <tbody>
          <% if (dashboard.priorityQueue.length === 0) { %>
            <tr><td colspan="3">No episodes in the queue yet.</td></tr>
          <% } else { %>
            <% dashboard.priorityQueue.forEach((item) => { %>
              <tr>
                <td><%= item.title %></td>
                <td><span class="status <%= item.statusClass %>"><%= item.statusLabel %></span></td>
                <td><%= item.dueLabel %></td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </article>

    <article class="panel">
      <div class="panel-header">
        <h2>Unlocks</h2>
        <span>All time</span>
      </div>
      <div class="stack">
        <% dashboard.unlockSummary.forEach((item) => { %>
          <div><span><%= item.label %></span><strong><%= item.value %></strong></div>
        <% }) %>
      </div>
    </article>
  </div>
</section>
