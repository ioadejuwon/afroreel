<section class="view" id="users" aria-label="User management">
  <div class="metric-grid compact">
    <% users.metrics.forEach((metric) => { %>
      <article class="metric-card">
        <span><%= metric.label %></span>
        <strong><%= metric.value %></strong>
        <em><%= metric.note %></em>
      </article>
    <% }) %>
  </div>
  <div class="panel">
    <table>
      <thead>
        <tr><th>User</th><th>Email</th><th>Coins</th><th>Last watched</th><th>Unlocks</th><th>Status</th></tr>
      </thead>
      <tbody>
        <% if (users.rows.length === 0) { %>
          <tr><td colspan="6">No mobile users found.</td></tr>
        <% } %>
        <% users.rows.forEach((user) => { %>
          <tr>
            <td><%= user.name %></td>
            <td><%= user.email %></td>
            <td><%= user.coinBalance %></td>
            <td><%= user.lastWatched %></td>
            <td><%= user.unlockNote %></td>
            <td><span class="status <%= user.statusClass %>"><%= user.statusLabel %></span></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>
