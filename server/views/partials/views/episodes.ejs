<section class="view" id="episodes" aria-label="Episode management">
  <div class="section-head split-head">
    <div>
      <h2>Episodes</h2>
      <span class="section-note"><%= episodes.length %> episode<%= episodes.length === 1 ? '' : 's' %> in the release queue.</span>
    </div>
    <button class="primary-button" type="button" data-focus-target="episode-form">New Episode</button>
  </div>

  <form class="panel content-form episode-composer" id="episode-form" method="post" action="<%= basePath %>/admin/episodes" data-episode-create-form>
    <div class="form-intro span-2">
      <p class="eyebrow">Create</p>
      <h3>Episode details</h3>
    </div>
    <% if (episodeFormError) { %>
      <div class="form-error span-2"><%= episodeFormError %></div>
    <% } %>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <label>
      <span>Series</span>
      <select name="seriesId" required>
        <option value="">Choose series</option>
        <% series.forEach((item) => { %>
          <option value="<%= item.id %>"><%= item.title %></option>
        <% }) %>
      </select>
    </label>
    <label>
      <span>Episode number</span>
      <input type="number" name="episodeNumber" min="1" required />
    </label>
    <label>
      <span>Title</span>
      <input name="title" required placeholder="The Photograph" />
    </label>
    <label>
      <span>Coin cost</span>
      <input type="number" name="coinCost" min="0" value="5" />
    </label>
    <label class="span-2">
      <span>Hook</span>
      <textarea name="hook" rows="3" placeholder="The one-line cliffhanger."></textarea>
    </label>
    <label>
      <span>Release date</span>
      <input type="date" name="releaseDate" />
    </label>
    <label>
      <span>Status</span>
      <select name="status">
        <option value="draft">Draft</option>
        <option value="live">Live</option>
      </select>
    </label>
    <label class="check-row">
      <input type="checkbox" name="isFree" />
      <span>Free episode</span>
    </label>
    <label class="span-2 video-create-dropzone" data-video-create-dropzone>
      <input type="file" accept="video/*" data-create-video-file required />
      <span>Video file</span>
      <strong data-create-video-file-name>Drop video here or choose file</strong>
      <em>MP4 or supported video file</em>
    </label>
    <span class="span-2 form-status" data-create-episode-status></span>
    <button class="primary-button" type="submit">Create Episode</button>
  </form>

  <div class="panel upload-panel">
    <div class="panel-header">
      <h2>Video Uploads</h2>
      <span>Cloudflare Stream</span>
    </div>
    <% if (episodes.length === 0) { %>
      <div class="empty-card action-empty">
        <strong>No episodes yet.</strong>
        <button class="ghost-button" type="button" data-focus-target="episode-form">Create first episode</button>
      </div>
    <% } else { %>
      <div class="episode-upload-list">
        <% episodes.forEach((episode) => { %>
          <article class="episode-upload-card" data-episode-id="<%= episode.id %>" data-video-uid="<%= episode.cloudflare_video_uid || '' %>">
            <div class="episode-main">
              <span class="episode-kicker">Ep <%= episode.episode_number %> · <%= episode.series_title %></span>
              <strong><%= episode.title %></strong>
              <div class="episode-meta">
                <span><%= episode.is_free ? 'Free' : 'Locked' %></span>
                <span><%= episode.is_free ? 0 : episode.coin_cost %> coins</span>
                <span data-video-state>
                  <% if (episode.cloudflare_ready) { %>
                    Ready
                  <% } else if (episode.cloudflare_video_uid) { %>
                    Processing
                  <% } else { %>
                    Missing video
                  <% } %>
                </span>
                <span class="status <%= episode.status === 'processing' ? 'review' : episode.status %>" data-status-label><%= episode.status %></span>
              </div>
            </div>
            <div class="upload-cell">
              <input type="file" accept="video/*" data-video-file />
              <div class="upload-actions">
                <button class="primary-button" type="button" data-upload-video>Upload</button>
                <% if (episode.cloudflare_video_uid) { %>
                  <button class="ghost-button" type="button" data-refresh-video>Refresh</button>
                <% } %>
              </div>
              <span data-upload-status></span>
            </div>
            <form class="inline-form" method="post" action="<%= basePath %>/admin/episodes/<%= episode.id %>/status" data-status-form data-entity-type="episode">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <input type="hidden" name="status" value="<%= episode.status === 'live' ? 'draft' : 'live' %>" />
              <button class="ghost-button" type="submit" data-status-button><%= episode.status === 'live' ? 'Draft' : 'Publish' %></button>
            </form>
          </article>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>
