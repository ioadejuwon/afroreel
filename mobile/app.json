{
  "expo": {
    "name": "AfroReel",
    "slug": "afroreel",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0A0F",
    "splash": {
      "backgroundColor": "#0A0A0F"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.afroreel.app",
      "buildNumber": "1",
      "requireFullScreen": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Required for profile photo.",
        "NSPhotoLibraryUsageDescription": "Required to select a profile photo."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0F"
      },
      "package": "com.afroreel.app",
      "versionCode": 1,
      "permissions": [
        "INTERNET",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {},
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-video"
    ],
    "scheme": "afroreel",
    "experiments": {
      "typedRoutes": true
    }
  }
}
